<div class="container text-center py-5 my-5 text-center">
    <div class="card pt-5">
        <a href="" data-toggle="modal" data-target="#profile">
            <% if(userImg.public_id && userImg.secure_url){ %>
              <img src="<%= userImg.secure_url %>" class="avatar  " style="border: #1CB5E0 solid 3px; border-radius: 100px;" alt="">
            <% } else { %>
                <img src="img/avatar.png" class="avatar  " style="border: #1CB5E0 solid 3px; border-radius: 100px;" alt="">
            <% } %>
        </a>
        <h3 class="py-2"><%= session.userName %></h3>
        <button    data-bs-toggle="modal"  data-bs-target="#share" id="OpenShareTap"   class="btn mybtn-default-outline"><i class="fas fa-share-alt"></i>  Share Profile</button>
    </div>
</div>


<!--  Share profile Modal -->
<div class="modal fade" id="share" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title">Share Profile</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body text-center">
        <a target="_blank" href="<%= link %>" class="text-primary fw-bold">
          <%= link %>
        </a>
      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
          Close
        </button>
      </div>

    </div>
  </div>
</div>

<!-- /modal -->



<!-- =================messages=================== -->
<div class="container text-center my-5 text-center">
    <div class="row">
        <% for( let i = 0; i < massage.length; i++ ) { %>
        <div class="col-md-12">
            <div class="card py-5">
                <% if (massage.length) { %>
                    <p> <%= massage[i].contant %></p>
                <% } %>
            </div>
        </div>
        <% } %>

        
        <% for( let index = 0; index == massage.length; index++ ) { %>
            <div class="col-md-12"> 
                <div class="card py-5">
                    <p>"You don't have any messages..." </p>
            </div>  
        <% } %>
    </div>
 
</div>








