                            <input style="border-radius: 9.5px; border: 1px solid rgba(128, 128, 128, 0.071);  background: rgba(128, 128, 128, 0.066);" class="form-control" placeholder="Enter your Name" type="text" name="name">
                            <input style="border-radius: 9.5px; border: 1px solid rgba(128, 128, 128, 0.071);  background: rgba(128, 128, 128, 0.066);" class="form-control" placeholder="Enter your email" type="email" name="email">

                            <select style="border-radius: 9.5px;  border: 1px solid rgba(128, 128, 128, 0.071);  background: rgba(128, 128, 128, 0.066); width: 100%; padding: 8px 10px;" class="form-select" aria-label="Default select example">
                              <option disabled selected hidden  >gender</option>
                              <option value="male">male</option>
                              <option value="female">female</option>
                           
                            </select>
                           
                            <input style="border-radius: 9.5px; border: 1px solid rgba(128, 128, 128, 0.071);  background: rgba(128, 128, 128, 0.066);" class="form-control" placeholder="Enter your Password" type="password" name="password">
                            <input style="border-radius: 9.5px;  border: 1px solid rgba(128, 128, 128, 0.071);  background: rgba(128, 128, 128, 0.066);" class="form-control" placeholder="Password Confirmation" type="password" name="PasswordConfirmation">
                      


