    <div class="LoaderConatiner">
        <div class="LoaderConatinerAfter"></div>
        <div class="loader"></div>
        <div class="LoaderConatinerBefore"></div>
    </div>




    <% if (error && error.length> 0) { %>
    <div class="alert alert-danger custom-alert" id="auto-close-alert">
        <%= error[0] %>
    </div>
    <% } %>
    <% if (success && success.length> 0) { %>
    <div class="alert alert-success custom-alert" id="auto-close-alert">
        <%= success[0] %>
    </div>
    <% } %>




