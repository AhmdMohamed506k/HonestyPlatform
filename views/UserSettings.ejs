                                <div class="card shadow settings-card mt-4 text-dark">

                                    <a href="#" id="OpenDeleteAccountTap"
                                        class=" middle-list text-decoration-none text-dark settings-item d-flex justify-content-between align-items-center border-bottom">
                                        <div class="d-flex align-items-center gap-2">
                                            <i class="fa-solid fa-trash-can" style="color: rgb(116, 192, 252);"></i>
                                            <span>Delete Your Account</span>
                                        </div>
                                        <i class="fa-solid fa-chevron-right text-muted"></i>
                                    </a>


                                </div>

                            </div>
                        </div>




