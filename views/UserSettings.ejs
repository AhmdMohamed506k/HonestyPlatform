                                    <a href="#" id="OpenChangeInfoTap"
                                        class=" first-list text-decoration-none text-dark settings-item d-flex justify-content-between align-items-center border-bottom">
                                        <div class="d-flex align-items-center gap-2">
                                            <i class="fa-solid fa-address-card" style="color: #1CB5E0;"></i>
                                            <span>Change User Informations</span>
                                        </div>
                                        <i class="fa-solid fa-chevron-right text-muted"></i>
                                    </a>

                                    <a href="#" id="OpenChangePassTap"
                                        class="text-decoration-none text-dark settings-item d-flex justify-content-between align-items-center border-bottom">
                                        <div class="d-flex align-items-center gap-2 ">
                                            <i class="fa-solid fa-fingerprint " style="color: #1CB5E0;"></i>
                                            <span class="ms-2">Change password</span>
