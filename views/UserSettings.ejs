                                        <img id="changeUserImgAvatar" src="img/avatar.png" class="avatar position-absolute " style="border: #1CB5E0 solid 3px; border-radius: 100px;" alt="">
                                        <% } %>
                                            <div id="changeUserImgAvatarPenIcon"  style="background-color: white; border-radius: 100px; width: 40px; height: 40px;   left: 40px; right: 0; top: 20px; border: #1CB5E0 solid 2px;"  class="position-absolute mx-auto d-flex justify-content-center  align-items-center">  <i class="fa-solid fa-pen" style="color: rgb(116, 192, 252);"></i></div>
                            </a>


                            <h3 style="margin-bottom: -30px; " class="py-2">
                                <%= userName %>
                            </h3>





                            <div class="page-wrapper text-white text-center ">

